---
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";
---

<!DOCTYPE html>
<html lang="ru">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero-section {
				text-align: center;
				padding: 4rem 1rem;
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 1.5rem;
			}
			.tagline {
				font-family: "Fira Code", monospace;
				color: var(--accent);
				letter-spacing: 0.1em;
				text-transform: uppercase;
				font-size: 0.9rem;
			}
			h1 {
				font-size: 4rem;
				line-height: 1.1;
				margin: 0;
				max-width: 800px;
			}
			.subtitle {
				font-size: 1.25rem;
				color: var(--text-secondary);
				max-width: 600px;
				margin: 0 auto;
			}
			.cta-buttons {
				display: flex;
				gap: 1rem;
				margin-top: 2rem;
			}
			.btn {
				padding: 1rem 2rem;
				border-radius: var(--radius);
				font-weight: 600;
				text-decoration: none;
				transition: var(--transition);
			}
			.btn-primary {
				background: var(--accent);
				color: #000;
				box-shadow: var(--glow-accent);
			}
			.btn-primary:hover {
				background: #fff;
				color: #000;
				box-shadow: 0 0 40px rgba(255, 255, 255, 0.6);
			}
			.btn-secondary {
				background: var(--bg-surface);
				border: var(--glass-border);
				color: var(--text-strong);
			}
			.btn-secondary:hover {
				background: var(--bg-surface-solid);
				border-color: rgba(255, 255, 255, 0.2);
				color: var(--text-strong);
			}

			.features {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
				gap: 2rem;
				margin-top: 4rem;
			}
			.card-link {
				text-decoration: none;
				color: inherit;
				display: block;
			}
			.card-link:hover {
				border-color: var(--accent);
				transform: translateY(-4px);
			}
			.card-link:hover h3 {
				color: var(--accent);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero-section">
				<span class="tagline">Альтернативная физика</span>
				<h1>
					<span class="gradient-text">Эфиро-динамика</span> и структура
					материи
				</h1>
				<p class="subtitle">
					Исследуем, как устроен наш мир на фундаментальном уровне.
					Забудьте про вероятности — добро пожаловать в инженерный
					подход к строению атома.
				</p>
				<div class="cta-buttons">
					<a
						href="/ru/blog/atom-structure-etherdynamics"
						class="btn btn-primary">Начать чтение</a
					>
					<a href="/ru/blog" class="btn btn-secondary">Все статьи</a>
				</div>
			</section>

			<section class="features">
				<a
					href="/ru/blog/atom-structure-etherdynamics"
					class="glass-panel card-link"
				>
					<h3>🔭 Прямые наблюдения</h3>
					<p>
						Мы анализируем реальные снимки атомов, полученные
						фотоионизационным микроскопом, а не математические
						абстракции.
					</p>
				</a>
				<div class="glass-panel">
					<h3>🌪️ Теория вихрей</h3>
					<p>
						Эфир возвращается. Узнайте, почему материя — это
						устойчивый тороидальный вихрь в сверхплотной среде.
					</p>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
